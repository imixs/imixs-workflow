      <bpmn2:documentation id="documentation_5j0r0g"><![CDATA[<?xml version="1.0"?>
<imixs-form>
  <imixs-form-section columns="3"  readonly="true" >
    <item name="document.company" type="text" label="Company: "  />
    <item name="document.type" type="text" label="Doument Type: " />
    <item name="document.language" type="text" label="Language: " />
  </imixs-form-section>

  <imixs-form-section columns="1" label="Customer Summary" readonly="true" >
    <item name="customer.summary" type="custom" path="markdown" />
  </imixs-form-section>

  

  <imixs-form-section columns="1" label="Product Catalog" readonly="false">
   <item name="customer.ref" 
      type="custom"  required="false"
      path="workitemlink"
      options="($workflowgroup:Customer)((type:workitem) OR (type:workitemarchive))"
      label="Customer:" />
   <item name="product.ref" 
      type="custom"  required="false"
      path="workitemlink"
      options="($workflowgroup:Product)((type:workitem) OR (type:workitemarchive))"
      label="Products:" />

  </imixs-form-section>


</imixs-form>]]></bpmn2:documentation>
