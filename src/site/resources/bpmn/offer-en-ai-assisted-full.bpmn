<for-each-ref item="order.history.ref">
Created: <itemvalue>$created</itemvalue>
<itemvalue>$workflowabstract</itemvalue> 

-----------------------------------------------------------------------------
</for-each-ref>]]]]><![CDATA[>
    </prompt>
</PromptDefinition>    ]]></bpmn2:documentation>
